    {
      "id": "macro_458y8c",
      "name": "Newmacro_1",
      "description": "",
      "language": "ts",
      "code": "const current = Number(api.readVariable('Counter2') ?? 0); api.writeVariable('Counter2', current + 1);",
      "enabled": true,
      "triggers": [
        {
          "type": "interval",
          "intervalMs": 1000
        }
      ]
    },
    {
      "id": "openValvePopup",
      "name": "Open valve popup",
      "description": "Open valve popup",
      "language": "ts",
      "code": "const prefix = String(args.prefix ?? \"\").trim();\nconst name = String(args.name ?? \"\").trim();\nconst index = Number(args.index ?? 0);\nconst valveId = String(args.valveId ?? \"\").trim();\nif (!prefix) {\n  log(\"openValvePopup: prefix is empty\");\n  return;\n}\nsetVar(\"SelectedValvePrefix\", prefix);\nsetVar(\"SelectedValveName\", name || prefix);\nsetVar(\"SelectedValveIndex\", index || 0);\nopenPopup(\"Popup_ValveControl\", {\n  title: \"Управление: \" + (name || prefix),\n  tagPrefix: prefix,\n  args: {\n    valveId: valveId || prefix,\n    valveName: name || prefix,\n    valvePrefix: prefix,\n    valveIndex: index || 0,\n  },\n});",
      "enabled": true
    },
    {
      "id": "valveOpen",
      "name": "Valve open command",
      "description": "Valve open command",
      "language": "ts",
      "code": "const ctx = getContext();\nconst params = (ctx && typeof ctx.parameters === \"object\" && ctx.parameters) ? ctx.parameters : {};\nconst paramPrefix = typeof params.valvePrefix === \"string\" ? params.valvePrefix.trim() : \"\";\nconst popupPrefix = typeof getCurrentTagPrefix() === \"string\" ? String(getCurrentTagPrefix()).trim() : \"\";\nconst prefix = paramPrefix || popupPrefix;\nif (!prefix) {\n  log(\"valveOpen: prefix is empty\");\n  return;\n}\nawait writeTag(prefix + \".OpenCmd\", true);\nawait writeTag(prefix + \".CloseCmd\", false);\nawait writeTag(prefix + \".Opened\", true);\nawait writeTag(prefix + \".Closed\", false);\nawait writeTag(prefix + \".State\", 2);",
      "enabled": true
    },
    {
      "id": "valveClose",
      "name": "Valve close command",
      "description": "Valve close command",
      "language": "ts",
      "code": "const ctx = getContext();\nconst params = (ctx && typeof ctx.parameters === \"object\" && ctx.parameters) ? ctx.parameters : {};\nconst paramPrefix = typeof params.valvePrefix === \"string\" ? params.valvePrefix.trim() : \"\";\nconst popupPrefix = typeof getCurrentTagPrefix() === \"string\" ? String(getCurrentTagPrefix()).trim() : \"\";\nconst prefix = paramPrefix || popupPrefix;\nif (!prefix) {\n  log(\"valveClose: prefix is empty\");\n  return;\n}\nawait writeTag(prefix + \".CloseCmd\", true);\nawait writeTag(prefix + \".OpenCmd\", false);\nawait writeTag(prefix + \".Closed\", true);\nawait writeTag(prefix + \".Opened\", false);\nawait writeTag(prefix + \".State\", 0);",
      "enabled": true
    }
  ],
