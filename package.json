{
  "name": "my-web-scada",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "init:dev": "node scripts/init.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:workspace": "pnpm -r --parallel dev",
    "dev:kill": "node scripts/kill-dev-ports.mjs",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @web-scada/shared test"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@serialport/bindings-cpp", "esbuild"]
  },
  "dependencies": {
    "@ant-design/v5-patch-for-react-19": "^1.0.3"
  }
}
